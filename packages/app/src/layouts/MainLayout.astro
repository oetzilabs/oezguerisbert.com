---
import "@fontsource/inter";
import "@fontsource/playfair-display";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

export type Props = {
  small?: boolean;
};

const { small } = Astro.props;
const theme = Astro.cookies.get("theme")?.value;
const isDark = theme !== "light";
---

<!doctype html>
<html
  lang="en"
  class:list={{
    dark: isDark,
  }}
>
  <head>
    <script is:inline>
      (function() {
        var t = document.cookie.match(/theme=([^;]+)/)?.[1];
        if (t !== "light") document.documentElement.classList.add("dark");
      })();
    </script>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-white dark:bg-black text-black dark:text-white flex-1 overflow-auto px-4 md:px-0 font-sans">
    <Header title={SITE_TITLE} small={small} />
    <main class="flex flex-col min-h-min pt-10 md:pt-12">
      <div
        class:list={[
          "container mx-auto flex flex-col h-full",
          {
            "max-w-[800px]": !!small,
          },
        ]}
      >
        <slot />
      </div>
    </main>
    <Footer small={small} />
  </body>
</html>
