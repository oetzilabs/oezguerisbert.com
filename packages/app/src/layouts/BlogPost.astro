---
import { getCollection, type CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import MainLayout from "./MainLayout.astro";
import dayjs from "dayjs";
import relativeTime from "dayjs/plugin/relativeTime";
dayjs.extend(relativeTime);

const { pathname } = Astro.url;

type Props = CollectionEntry<"blog">["data"];

const production = import.meta.env.MODE === "production";

const { title, description, pubDate, updatedDate, heroImage, status } = Astro.props;
const posts = (await getCollection("blog"))
  .filter((p) => !pathname.includes(p.id))
  .filter((p) => (production ? ["published", "archived"] : ["published", "draft", "archived"]).includes(p.data.status))
  .sort((a, b) => (a.data.updatedDate ?? a.data.pubDate).valueOf() - (b.data.updatedDate ?? b.data.pubDate).valueOf())
  .slice(0, 3);
---

<MainLayout small>
  <article class="flex flex-col w-full h-full">
    {heroImage && (
      <div class="w-full flex flex-col overflow-clip border border-neutral-300 dark:border-neutral-700 animate-fade-up">
        <img src={heroImage} alt="" />
      </div>
    )}
    <div class="flex flex-col gap-2 py-4 w-full pb-24 h-full animate-fade-up-d1">
      <div class="flex flex-col gap-8 w-full h-max">
        <div class="flex flex-row justify-between w-full gap-2">
          <div class="w-max flex flex-row gap-2 items-center">
            {
              status === "draft" && (
                <span class="label border border-neutral-400 dark:border-neutral-600 px-1.5 py-0.5">Draft</span>
              )
            }
            {
              status === "archived" && (
                <span class="label border border-neutral-400 dark:border-neutral-600 px-1.5 py-0.5">Archived</span>
              )
            }
            {
              status === "hidden" && (
                <span class="label border border-neutral-400 dark:border-neutral-600 px-1.5 py-0.5">Hidden</span>
              )
            }
            <FormattedDate date={pubDate} />
          </div>
          {
            updatedDate && (
              <div class="text-xs flex flex-row gap-2 items-center">
                <span class="label">Updated</span>
                <time
                  datetime={updatedDate.toISOString()}
                  class="border border-neutral-300 dark:border-neutral-700 px-1.5 py-0.5 text-xs font-sans"
                >
                  {dayjs(updatedDate).fromNow()}
                </time>
              </div>
            )
          }
        </div>
        <div class="flex flex-col gap-4 w-full h-max">
          <h1 class="w-full my-0 font-heading italic font-bold text-3xl md:text-4xl">{title}</h1>
          <span class="w-full text-sm font-sans">{description}</span>
        </div>
      </div>
      <div
        class="prose max-w-none prose-neutral dark:prose-invert w-full prose-p:text-justify prose-p:leading-snug prose-a:font-semibold prose-headings:mt-5 prose-headings:mb-3 prose-headings:tracking-tight animate-fade-up-d2"
      >
        <slot />
      </div>
      <div class="grow items-start flex flex-col justify-start"></div>
      {
        posts.length > 0 ? (
          <div class="flex flex-col items-start w-full gap-6 pt-4 animate-fade-up-d2">
            <div class="w-full flex flex-row items-center gap-4">
              <div class="flex-1 h-0 border-t border-neutral-300 dark:border-neutral-700" />
              <span class="label">More Blogs</span>
              <div class="flex-1 h-0 border-t border-neutral-300 dark:border-neutral-700" />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-2 w-full">
              {posts.map((b) => (
                <a
                  href={`/blogs/${b.id}`}
                  class="card no-underline flex flex-col gap-2"
                >
                  <span class="w-full font-heading italic text-sm">{b.data.title}</span>
                  <FormattedDate date={b.data.pubDate} relative />
                </a>
              ))}
            </div>
          </div>
        ) : null
      }
    </div>
  </article>
</MainLayout>
