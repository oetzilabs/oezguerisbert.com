---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";

export const prerender = true;

const projects = (await getCollection("project"))
  .filter((p) => ["published", "draft", "archived"].includes(p.data.status))
  .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
---

<MainLayout small>
  <section class="flex flex-col w-full pb-20 gap-6">
    <div class="flex flex-col gap-1 animate-fade-up">
      <span class="label text-neutral-500">Hands-on work</span>
      <h1 class="heading-xl">Projects</h1>
    </div>
    {
      projects.length > 0 ? (
        <div class="grid grid-cols-1 gap-2 w-full">
          {projects.map((post, i) => (
            <a
              href={`/projects/${post.id}/`}
              style={`animation-delay: ${i * 0.06}s`}
              class="card no-underline flex flex-col w-full gap-4 animate-fade-up"
            >
              {post.data.heroImage && (
                <img src={post.data.heroImage} alt="" class="border border-neutral-300 dark:border-neutral-700" />
              )}
              <div class="flex flex-col gap-2">
                <div class="flex flex-row items-center justify-between gap-2 w-full">
                  <h2 class="font-heading italic text-base">{post.data.title}</h2>
                  <FormattedDate date={post.data.pubDate} />
                </div>
                <span class="text-xs font-sans text-neutral-500 w-full">{post.data.description}</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm font-sans text-neutral-500 text-center">There are currently no projects.</p>
      )
    }
  </section>
</MainLayout>
