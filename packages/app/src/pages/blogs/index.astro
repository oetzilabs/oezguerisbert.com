---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";

export const prerender = true;

const production = import.meta.env.MODE === "production";

const posts = (await getCollection("blog"))
  .filter((p) => (production ? ["published", "archived"] : ["published", "draft", "archived"]).includes(p.data.status))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<MainLayout small>
  <section class="flex flex-col w-full pb-20 gap-8">
    <div class="flex flex-col gap-1 animate-fade-up">
      <span class="label text-neutral-500">Insights & tutorials</span>
      <h1 class="heading-xl">Blog</h1>
    </div>
    {
      posts.length > 0 ? (
        <div class="flex flex-col w-full gap-3">
          {posts.map((post, i) => (
            <a
              href={`/blogs/${post.id}/`}
              style={`animation-delay: ${i * 0.06}s`}
              class:list={[
                "group flex flex-col w-full border border-neutral-300 dark:border-neutral-800 no-underline overflow-hidden animate-fade-up",
                "hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-all duration-200",
                {
                  "opacity-50 hover:opacity-70": post.data.status === "archived",
                  "border-dashed": post.data.status === "draft",
                },
              ]}
            >
              {
                post.data.heroImage && (
                  <div class="w-full h-32 md:h-40 overflow-clip border-b border-neutral-300 dark:border-neutral-800">
                    <img
                      src={post.data.heroImage}
                      alt=""
                      class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
                    />
                  </div>
                )
              }
              <div class="flex flex-col gap-2.5 p-4 md:p-5">
                <div class="flex flex-col gap-1.5">
                  <div class="flex flex-row items-start justify-between gap-3">
                    <h2 class="font-heading italic font-bold text-base md:text-lg leading-tight">
                      {post.data.title}
                    </h2>
                    <span class="shrink-0 text-[11px] text-neutral-400 font-mono mt-0.5">
                      <FormattedDate date={post.data.pubDate} relative />
                    </span>
                  </div>
                  <p class="text-xs md:text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed m-0">
                    {post.data.description}
                  </p>
                </div>
                <div class="flex flex-row items-center gap-2 pt-0.5">
                  {
                    post.data.status === "draft" && (
                      <span class="text-[10px] font-sans font-semibold uppercase tracking-[0.12em] text-neutral-500 border border-neutral-400 dark:border-neutral-600 px-1.5 py-0.5 leading-none">
                        Draft
                      </span>
                    )
                  }
                  {
                    post.data.status === "archived" && (
                      <span class="text-[10px] font-sans font-semibold uppercase tracking-[0.12em] text-neutral-500 border border-neutral-400 dark:border-neutral-600 px-1.5 py-0.5 leading-none">
                        Archived
                      </span>
                    )
                  }
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm font-sans text-neutral-500 text-center">There are currently no posts.</p>
      )
    }
  </section>
</MainLayout>
