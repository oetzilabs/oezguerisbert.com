---
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ToggleBrightness";

export type Props = {
  small?: boolean;
  title: string;
  theme?: "light" | "dark";
};

const { small } = Astro.props;
---

<header class="w-full flex flex-row items-center justify-center bg-white dark:bg-black border-b border-neutral-200 dark:border-neutral-900">
  <nav
    class:list={[
      "container mx-auto flex flex-row items-center h-full py-4",
      {
        "max-w-[800px]": !!small,
      },
    ]}
  >
    <a class="font-heading italic text-lg md:text-xl w-max" href="/">
      <span class="hidden md:inline">Özgür Isbert</span>
      <span class="inline md:hidden">ØI</span>
    </a>
    <div class="flex-1" />
    <div class="flex flex-row items-center gap-0 md:gap-1">
      <HeaderLink href="/blogs">Blogs</HeaderLink>
      <HeaderLink href="/projects">Projects</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
    <div class="w-px h-5 bg-neutral-300 dark:bg-neutral-700 mx-2 md:mx-3" />
    <ThemeToggle client:load />
  </nav>
</header>
