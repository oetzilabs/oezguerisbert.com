---
interface Props {
  date: Date;
  relative?: boolean;
}
import dayjs from "dayjs";
import relativeTime from "dayjs/plugin/relativeTime";
dayjs.extend(relativeTime);

const { date, relative } = Astro.props;
const r = relative ? dayjs(date).fromNow() : dayjs(date).format("MMM D, YYYY");
---

<time datetime={date.toISOString()}>
  {r}
</time>
